{
  "name": "astroroute",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/tunnel",
    "apps/cli",
    "apps/web",
    "apps/cron",
    "apps/internal-check",
    "packages/core",
    "packages/express-plugin",
    "packages/nestjs-plugin",
    "packages/next-plugin",
    "packages/vite-plugin"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:tunnel": "cd apps/tunnel && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build": "npm run build:tunnel && npm run build:cli && npm run build:web && npm run build:cron && npm run build:internal-check",
    "build:tunnel": "cd apps/tunnel && npm run build",
    "build:cli": "cd apps/cli && npm run build",
    "build:web": "cd apps/web && npm run build",
    "build:cron": "cd apps/cron && npm run build",
    "build:internal-check": "cd apps/internal-check && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@polar-sh/sdk": "^0.48.1",
    "@tanstack/react-start": "^1.168.25",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.13.2",
    "better-auth": "^1.3.34",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "fumadocs-core": "^16.9.3",
    "fumadocs-ui": "^16.9.3",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zustand": "^5.0.9"
  }
}
